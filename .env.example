# Environment Variables — salon-booking-saas
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# .env.local is git-ignored and will NOT be committed.
# Never commit real credentials to the repository.
#
# ─── Supabase ────────────────────────────────────────────────
#
# Your Supabase project URL.
# Found at: Supabase Dashboard → Project Settings → API → Project URL
#
VITE_SUPABASE_URL=

# Your Supabase anonymous (public) key.
# Found at: Supabase Dashboard → Project Settings → API → anon / public
# This key is safe to expose in the frontend (RLS enforces access).
#
VITE_SUPABASE_ANON_KEY=

# ⚠️  NEVER add SUPABASE_SERVICE_ROLE_KEY here.
#     The service_role key bypasses RLS and must only be used
#     in server-side Edge Functions, never in frontend code.

# ─── Deployment configuration ────────────────────────────────
#
# Vercel:
#   Add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in:
#   Vercel → Project → Settings → Environment Variables
#   Set for: Production, Preview, Development environments.
#
# GitHub Actions:
#   Add the same two vars in:
#   GitHub → Repository → Settings → Secrets and variables → Actions
#   (Use Repository Variables, not Secrets, since they are safe public values)
#
# ─── Base44 (legacy — do not remove until migration is complete) ──
#
# These were used by the original Base44 SDK.
# They will be removed in a future PR once all pages are migrated.
#
VITE_BASE44_APP_ID=
VITE_BASE44_BACKEND_URL=
